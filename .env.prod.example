# Production environment variables for Hospital HIS
# Usage: cp .env.prod.example .env.prod  then fill in real values
# Pass to docker compose: docker compose -f docker-compose.prod.yml --env-file .env.prod ...
# WARNING: Never commit .env.prod to git — it contains real secrets.

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
# Password for the "hospital" database user
POSTGRES_PASSWORD=change_me_strong_password_here

# ─── MinIO (object storage) ───────────────────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change_me_minio_password_here
# Bucket name — created automatically by the backend on first run
MINIO_BUCKET=hospital-files

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Use a long random string: openssl rand -hex 32
JWT_SECRET=change_me_jwt_secret_here
# Token expiry in hours (default: 24)
JWT_EXPIRE_HOUR=24

# ─── WeChat Enterprise (optional) ─────────────────────────────────────────────
# Set WECHAT_ENABLED=true and fill in credentials to enable WeChat SSO + push
WECHAT_ENABLED=false
# WECHAT_CORP_ID=your_corp_id
# WECHAT_AGENT_ID=1000001
# WECHAT_SECRET=your_app_secret
# WECHAT_CALLBACK=https://your.domain.com/api/auth/wechat/callback
