# HIS Backend Environment Variables
# Copy to .env and modify as needed

# Server
HIS_SERVER_PORT=8080
HIS_SERVER_MODE=debug  # debug / release / test

# Database (PostgreSQL)
HIS_DATABASE_HOST=localhost
HIS_DATABASE_PORT=5432
HIS_DATABASE_USER=hospital
HIS_DATABASE_PASSWORD=hospital123
HIS_DATABASE_DBNAME=hospital_db
HIS_DATABASE_SSLMODE=disable

# Redis
HIS_REDIS_HOST=localhost
HIS_REDIS_PORT=6379
HIS_REDIS_PASSWORD=
HIS_REDIS_DB=0

# JWT
HIS_JWT_SECRET=change-me-in-production-use-a-long-random-string
HIS_JWT_EXPIRE_HOUR=24

# MinIO
HIS_MINIO_ENDPOINT=localhost:9000
HIS_MINIO_ACCESS_KEY=minioadmin
HIS_MINIO_SECRET_KEY=minioadmin123
HIS_MINIO_BUCKET=hospital
HIS_MINIO_USE_SSL=false
